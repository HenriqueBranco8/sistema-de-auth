{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Server",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "node",
            "runtimeArgs": ["--require", "ts-node/register"],
            "program": "${workspaceFolder}/src/server.ts",
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ],
            "envFile": "${workspaceFolder}/.env",
            "cwd": "${workspaceFolder}",
            "sourceMaps": true
        }
    ]
}
