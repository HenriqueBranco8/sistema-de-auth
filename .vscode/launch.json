{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Server",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
            "program": "${workspaceFolder}/src/server.ts",
            "skipFiles": ["<node_internals>/**"],
            "envFile": "${workspaceFolder}/.env",
            "cwd": "${workspaceFolder}",
            "sourceMaps": true
        }
    ]
}